rules_version = '2';

// Security model for MLE.
//
// Core principle (the lesson from the previous project): clients may only
// mutate their OWN profile and may only CREATE matches. Everything that affects
// shared or derived state — joining, leaving, capacity, status — is done by
// Cloud Functions using the Admin SDK, which bypasses these rules. Clients can
// never write playerIds / status directly.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Users ---------------------------------------------------------------
    // A user reads/writes only their own profile document.
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid);
      allow delete: if false; // profiles are not client-deletable
    }

    // --- Matches -------------------------------------------------------------
    match /matches/{matchId} {
      // Any signed-in user can browse matches.
      allow read: if isSignedIn();

      // Direct client writes are DENIED. Create/join/leave/cancel all go
      // through Cloud Functions (Admin SDK), which are not subject to these
      // rules. This makes the server the single source of truth for
      // playerIds, status, and spot counts.
      allow write: if false;

      // Participant records are likewise managed server-side.
      match /participants/{uid} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }
  }
}
